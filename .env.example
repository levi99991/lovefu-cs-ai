# 大島樂眠 AI 輔睡員 — 環境變數範本
# 複製為 .env 並填入實際值。Railway 在 Variables 頁面逐項設定即可。

# ============================================================
# OpenAI（必填）
# ============================================================
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXX
LLM_MODEL_SIMPLE=gpt-4o-mini
LLM_MODEL_COMPLEX=gpt-4o

# ============================================================
# Shopline 後台（mock 模式可不填）
# ============================================================
# SHOPLINE_MODE=mock         → 用 mock_data.py 假資料，不打真實 API（預設）
# SHOPLINE_MODE=production   → 打真實 Shopline Admin API（需 Token）
SHOPLINE_MODE=mock

# Production 模式才需要：
SHOPLINE_STORE_HANDLE=lovefu321930
SHOPLINE_ACCESS_TOKEN=
SHOPLINE_API_VERSION=v20260301

# ============================================================
# 物流（舊版 logistics，保留以兼容；新系統請用 WMS 區塊）
# ============================================================
LOGISTICS_API_BASE=
LOGISTICS_API_KEY=

# ============================================================
# WMS 暢流物流（lovefu.wms.changliu.com.tw）
# ============================================================
# WMS_MODE=mock         → 用 mock_wms_data.py 假資料（預設，本機 / Demo 安全）
# WMS_MODE=production   → 打真實 WMS API（需 BasicAuth + AES key）
WMS_MODE=mock
WMS_BASE_URL=https://lovefu.wms.changliu.com.tw

# Production 模式必填（從 WMS 暢流後台「API 設定」頁取得）：
WMS_API_ID=
WMS_API_KEY=
# 收件人姓名/電話 AES-128-ECB 解密 key（從 WMS 後台「API 設定」頁取得）
WMS_PII_AES_KEY=
# Token 快取 TTL（秒，預設 55 分鐘，WMS JWT 實際 1 小時）
WMS_TOKEN_TTL_SEC=3300

# ============================================================
# 門市追客（cs-instore）
# ============================================================
# LINE OA ID（用於產生門市 QR 加好友連結）
LINE_OA_ID=@lovefu
# 14 天內每位顧客最多發送追客訊息則數（硬上限，可調低不可調高）
INSTORE_MAX_MSG_PER_14D=5
# 偵測封鎖即自動暫停追客
INSTORE_PAUSE_ON_BLOCK=true
# 強制真人確認才發送（不可關閉）
INSTORE_DRAFT_REVIEW_REQUIRED=true

# ============================================================
# 對話記憶
# ============================================================
# MEMORY_BACKEND=dict   → 記憶體儲存，重啟即消失（適合本機 / Demo）
# MEMORY_BACKEND=redis  → Redis 持久化（建議生產環境）
MEMORY_BACKEND=dict

# Redis 模式才需要：
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================
# Omnichat 共存：mute 持續時間
# ============================================================
MUTE_AFTER_AGENT_REPLY_MIN=30
MUTE_AFTER_TAKEOVER_HOURS=24

# ============================================================
# Knowledge 路徑覆蓋（一般不用動）
# ============================================================
# KNOWLEDGE_PATH=/app/lovefu-cs-knowledge/references

# ============================================================
# LLM 雙供應商 Fallback（v2.2 新增）
# ============================================================
ANTHROPIC_API_KEY=
CLAUDE_MODEL_SIMPLE=claude-sonnet-4-20250514
CLAUDE_MODEL_COMPLEX=claude-sonnet-4-20250514
LLM_PROVIDER_ORDER=openai,anthropic

# ============================================================
# 意圖分類
# ============================================================
INTENT_FAST_PATH_CONFIDENCE=0.75
MESSAGE_DEBOUNCE_SEC=1.5

# ============================================================
# Handoff 轉人工（v2.2 新增）
# ============================================================
HANDOFF_REMIND_ENABLED=true
HANDOFF_STORE_BACKEND=memory
HANDOFF_USE_CELERY=false

# Celery/Redis（HANDOFF_USE_CELERY=true 時）
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================================
# 通知通道（v2.2 新增）
# ============================================================
LINE_NOTIFY_TOKEN=
LINE_NOTIFY_TAICHUNG=
LINE_NOTIFY_TAIPEI=
LINE_NOTIFY_KAOHSIUNG=
LINE_NOTIFY_HQ=
SLACK_HANDOFF_WEBHOOK=
OMNICHAT_API_KEY=
OMNICHAT_BASE_URL=https://api.omnichat.com.tw

# Email 通知
HANDOFF_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
HANDOFF_EMAIL_FROM=ai-advisor@lovefu.tw
HANDOFF_EMAIL_TO_HQ=
NOTIFY_MAX_RETRIES=2

# HRM 值班系統
HRM_API_URL=
HRM_API_KEY=
HRM_CACHE_TTL=300

# 總部客服
HQ_OPEN_HOUR=9
HQ_CLOSE_HOUR=22

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# 審計日誌 Sink（cs-guard.audit_logger）
# ============================================================
# 可逗號分隔多選：stdout,jsonl_file,d1
# - stdout      → Python logger（開發預設）
# - jsonl_file  → 本機 append-only JSONL 檔
# - d1          → Cloudflare D1（非阻塞 queue；生產建議）
AUDIT_SINK=stdout

# jsonl_file sink 路徑
AUDIT_JSONL_PATH=/tmp/lovefu_audit.jsonl

# d1 sink 需填（Cloudflare Dashboard → Workers & Pages → D1 → 你的 DB）
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_API_TOKEN=
CF_D1_AUDIT_TABLE=audit_log

